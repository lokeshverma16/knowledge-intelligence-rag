# ---- OpenAI ----
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- AWS / S3 (only required for private buckets) ----
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_DEFAULT_REGION=us-east-1

# ---- ChromaDB ----
# When running via docker-compose, the api container talks to the
# chromadb container over HTTP. For a single-process local run, leave
# CHROMA_HOST unset and the app will use an embedded persistent client.
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_DB_DIR=./data/chromadb
CHROMA_COLLECTION=enterprise_knowledge

# ---- Retrieval / chunking ----
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=5

# ---- App ----
LOG_LEVEL=INFO
ENVIRONMENT=development
PORT=5000
